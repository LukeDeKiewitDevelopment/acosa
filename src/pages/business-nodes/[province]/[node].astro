---
import { render, getCollection } from "astro:content";
import { getImage } from "astro:assets";
import Layout from "@/layouts/Layout.astro";
import {
  getNodes,
  getPublishedProperties,
  provinceLabel,
  propertyTypeLabel,
} from "@/lib/content";
import { Section } from "@/components/custom/section";
import { NodeDetail } from "@/components/custom/node-detail";
import type { FeaturedPropertyItem } from "@/components/custom/featured-properties";

export const prerender = true;

export async function getStaticPaths() {
  const nodes = await getNodes();
  return nodes.map((node) => ({
    params: { province: node.data.province, node: node.id },
    props: { node },
  }));
}

const { node } = Astro.props;
const { Content } = await render(node);
const seo = node.data.seo;

const heroImg = await getImage({
  src: node.data.heroImage,
  widths: [800, 1200, 1600],
  sizes: "100vw",
});

const nodeProperties = (await getPublishedProperties()).filter(
  (property) => property.data.businessNode.id === node.id,
);

const propertyItems: FeaturedPropertyItem[] = await Promise.all(
  nodeProperties.map(async (property) => {
    const img = await getImage({
      src: property.data.heroImage,
      widths: [400, 800],
      sizes: "(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw",
    });
    return {
      id: property.id,
      name: property.data.name,
      propertyTypeLabel: propertyTypeLabel(property.data.propertyType),
      approved: property.data.acosaApproved.approved,
      shortDescription: property.data.shortDescription,
      image: {
        src: img.src,
        srcSet: img.srcSet.attribute || undefined,
        sizes: img.attributes.sizes,
        width: img.attributes.width,
        height: img.attributes.height,
      },
      imageAlt: property.data.imageAlt || property.data.name,
    };
  }),
);

// Nearby Convenience is derived: unique tag ids across this node's
// properties, in first-seen order, resolved to names.
const nearbyIds: string[] = [];
for (const property of nodeProperties) {
  for (const tag of property.data.nearbyConvenience) {
    if (!nearbyIds.includes(tag.id)) nearbyIds.push(tag.id);
  }
}
const nearbyTags = await getCollection("nearbyConvenience");
const nearby = nearbyIds
  .map((id) => nearbyTags.find((tag) => tag.id === id)?.data.name)
  .filter((name): name is string => Boolean(name));
---

<Layout title={seo?.title || `${node.data.name} | Acosa`}>
  <Section className="mt-28 mb-28">
    <NodeDetail
      node={{
        id: node.id,
        name: node.data.name,
        city: node.data.city,
        province: node.data.province,
        provinceLabel: provinceLabel(node.data.province),
        mapUrl: node.data.mapUrl ?? "",
        image: {
          src: heroImg.src,
          srcSet: heroImg.srcSet.attribute || undefined,
          sizes: heroImg.attributes.sizes,
          width: heroImg.attributes.width,
          height: heroImg.attributes.height,
        },
        imageAlt: node.data.imageAlt || node.data.name,
      }}
      properties={propertyItems}
      highlights={node.data.businessHighlights}
      nearby={nearby}
    >
      <Content />
    </NodeDetail>
  </Section>
</Layout>
