---
import { getEntry, render } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '@/layouts/Layout.astro';

export const prerender = true;

const page = await getEntry('forCompaniesPage', 'for-companies');
if (!page) throw new Error('For Companies page content not found');
const { Content } = await render(page);
const seo = page.data.seo;
---

<Layout title={seo?.title || 'For Companies | Acosa'}>
  <section>
    <h1>{page.data.heroHeading}</h1>
    {page.data.heroImage && <Image src={page.data.heroImage} alt="" widths={[640, 1024, 1600]} sizes="100vw" />}
  </section>

  <section>
    <Content />
  </section>

  <!-- Corporate CTA -->
  <section>
    <h2>Coordinate travel for a team?</h2>
    <a href="/contact">Talk to us about corporate stays</a>
  </section>
</Layout>
