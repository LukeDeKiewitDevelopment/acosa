---
import { render } from "astro:content";
import { getImage } from "astro:assets";
import Layout from "@/layouts/Layout.astro";
import {
  getPublishedProperties,
  resolvePropertyTags,
  getTestimonialsForProperty,
  propertyTypeLabel,
} from "@/lib/content";
import { Section } from "@/components/custom/section";
import {
  PropertyGallery,
  type PropertyGallerySlide,
} from "@/components/custom/property-gallery";
import { PropertyDetail } from "@/components/custom/property-detail";

export const prerender = true;

export async function getStaticPaths() {
  const properties = await getPublishedProperties();
  return properties.map((property) => ({
    params: { slug: property.id },
    props: { property },
  }));
}

const { property } = Astro.props;
const { Content } = await render(property);
const { essentials, facilities, nearbyConvenience, perfectFor } =
  await resolvePropertyTags(property);
const testimonials = await getTestimonialsForProperty(property.id);
const seo = property.data.seo;

// Slides = heroImage first, then gallery[] in order.
const slideSources = [
  {
    image: property.data.heroImage,
    alt: property.data.imageAlt || property.data.name,
  },
  ...property.data.gallery.map((entry) => ({
    image: entry.image,
    alt: entry.alt || property.data.name,
  })),
];

const slides: PropertyGallerySlide[] = await Promise.all(
  slideSources.map(async (slide) => {
    const img = await getImage({
      src: slide.image,
      widths: [800, 1200, 1600],
      sizes: "(min-width: 1024px) 66vw, 100vw",
    });
    return {
      image: {
        src: img.src,
        srcSet: img.srcSet.attribute || undefined,
        sizes: img.attributes.sizes,
        width: img.attributes.width,
        height: img.attributes.height,
      },
      alt: slide.alt,
    };
  }),
);
---

<Layout title={seo?.title || `${property.data.name} | Acosa`}>
  <Section className="mt-28">
    <PropertyGallery client:load slides={slides} />
  </Section>

  <Section className="mt-16 mb-28">
    <PropertyDetail
      property={{
        name: property.data.name,
        propertyTypeLabel: propertyTypeLabel(property.data.propertyType),
        approved: property.data.acosaApproved.approved,
        score: property.data.acosaApproved.score,
        shortDescription: property.data.shortDescription,
        address: property.data.location.address,
        mapUrl: property.data.location.mapUrl ?? "",
        whatsapp: property.data.contact.whatsapp,
        phone: property.data.contact.phone,
        email: property.data.contact.email,
      }}
      essentials={essentials.map((tag) => ({
        name: tag.data.name,
        icon: tag.data.icon,
      }))}
      perfectFor={perfectFor.map((tag) => tag.data.name)}
      facilities={facilities.map((tag) => tag.data.name)}
      nearby={nearbyConvenience.map((tag) => tag.data.name)}
      testimonials={testimonials.map((testimonial) => ({
        reviewer: testimonial.data.reviewer,
        review: testimonial.data.review,
        rating: testimonial.data.rating,
      }))}
    >
      <Content />
    </PropertyDetail>
  </Section>
</Layout>
