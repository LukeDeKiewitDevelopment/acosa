---
import { getCollection } from "astro:content";
import { Image, getImage } from "astro:assets";
import Layout from "@/layouts/Layout.astro";
import {
  getHomePage,
  getNodes,
  getPopularNodes,
  getPublishedProperties,
  getFeaturedProperties,
  getGeneralTestimonials,
  getSiteSettings,
  getActiveProvinces,
  whatsappLink,
  provinceLabel,
  propertyTypeLabel,
} from "@/lib/content";
import { Hero } from "@/components/custom/hero";
import { Section } from "@/components/custom/section";
import {
  BusinessNodeSearch,
  type BusinessNodeSearchItem,
} from "@/components/custom/business-node-search";
import { TrustIcons } from "@/components/custom/trust-icons";
import {
  PopularNodes,
  type PopularNodeItem,
} from "@/components/custom/popular-nodes";
import {
  FeaturedProperties,
  type FeaturedPropertyItem,
} from "@/components/custom/featured-properties";

export const prerender = true;

const page = await getHomePage();
const { hero, founderStrip, trustStrip, whyAcosaPreview, ownerCta, seo } =
  page.data;

const popularNodes = await getPopularNodes();
const featuredProperties = await getFeaturedProperties();
const essentials = await getCollection("essentials");
const testimonials = await getGeneralTestimonials();
const settings = await getSiteSettings();
const provinces = await getActiveProvinces();

const nodes = await getNodes();
const properties = await getPublishedProperties();

const searchNodes: BusinessNodeSearchItem[] = await Promise.all(
  nodes.map(async (node) => {
    const img = await getImage({
      src: node.data.heroImage,
      widths: [400, 800, 1200],
      sizes: "(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw",
    });
    return {
      id: node.id,
      name: node.data.name,
      province: node.data.province,
      featured: node.data.featured,
      image: {
        src: img.src,
        srcSet: img.srcSet.attribute || undefined,
        sizes: img.attributes.sizes,
        width: img.attributes.width,
        height: img.attributes.height,
      },
      imageAlt: node.data.imageAlt || node.data.name,
      highlights: node.data.businessHighlights.map((h) => h.title),
      propertyNames: properties
        .filter((p) => p.data.businessNode.id === node.id)
        .map((p) => p.data.name),
    };
  }),
);

const popularNodeItems: PopularNodeItem[] = await Promise.all(
  popularNodes.map(async (node) => {
    const img = await getImage({
      src: node.data.heroImage,
      widths: [400, 800],
      sizes: "(min-width: 1024px) 25vw, (min-width: 640px) 50vw, 100vw",
    });
    return {
      id: node.id,
      name: node.data.name,
      city: node.data.city,
      province: node.data.province,
      image: {
        src: img.src,
        srcSet: img.srcSet.attribute || undefined,
        sizes: img.attributes.sizes,
        width: img.attributes.width,
        height: img.attributes.height,
      },
      imageAlt: node.data.imageAlt || node.data.name,
    };
  }),
);

const featuredPropertyItems: FeaturedPropertyItem[] = await Promise.all(
  featuredProperties.map(async (property) => {
    const img = await getImage({
      src: property.data.heroImage,
      widths: [400, 800],
      sizes: "(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw",
    });
    return {
      id: property.id,
      name: property.data.name,
      propertyTypeLabel: propertyTypeLabel(property.data.propertyType),
      approved: property.data.acosaApproved.approved,
      shortDescription: property.data.shortDescription,
      image: {
        src: img.src,
        srcSet: img.srcSet.attribute || undefined,
        sizes: img.attributes.sizes,
        width: img.attributes.width,
        height: img.attributes.height,
      },
      imageAlt: property.data.imageAlt || property.data.name,
    };
  }),
);
---

<Layout
  title={seo?.title || "Acosa | Vetted Business Accommodation in South Africa"}
>
  <Section fullWidth className="m-0">
    <Hero
      heading={hero.heading}
      subheading={hero.subheading}
      image={hero.image}
      overlay={{
        opacity: hero.overlayOpacity,
      }}
      contentClassName="text-background"
    />
  </Section>

  <Section>
    <BusinessNodeSearch nodes={searchNodes} client:load />
  </Section>

  <Section>
    <TrustIcons items={trustStrip} />
  </Section>

  <Section>
    <PopularNodes items={popularNodeItems} />
  </Section>

