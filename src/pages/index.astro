---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import Layout from "@/layouts/Layout.astro";
import {
  getHomePage,
  getPopularNodes,
  getFeaturedProperties,
  getGeneralTestimonials,
  getSiteSettings,
  getActiveProvinces,
  whatsappLink,
  provinceLabel,
  propertyTypeLabel,
} from "@/lib/content";
import { Hero } from "@/components/custom/hero";
import { Section } from "@/components/custom/section";
import { BusinessNodeSearch } from "@/components/custom/business-node-search";

export const prerender = true;

const page = await getHomePage();
const { hero, founderStrip, whyAcosaPreview, ownerCta, seo } = page.data;

const popularNodes = await getPopularNodes();
const featuredProperties = await getFeaturedProperties();
const essentials = await getCollection("essentials");
const testimonials = await getGeneralTestimonials();
const settings = await getSiteSettings();
const provinces = await getActiveProvinces();

// Plain, serializable suggestions shown before the client-side fetch of
// /search.json resolves — avoids an empty results panel on first paint.
const popularNodesForSearch = popularNodes.map((node) => ({
  slug: node.id,
  name: node.data.name,
  url: `/business-nodes/${node.data.province}/${node.id}`,
  provinceLabel: provinceLabel(node.data.province),
}));
---

<Layout
  title={seo?.title || "Acosa | Vetted Business Accommodation in South Africa"}
>
  <Hero
    heading={hero.heading}
    subheading={hero.subheading}
    image={hero.image}
    overlay={{
      opacity: hero.overlayOpacity,
    }}
    contentClassName="text-background"
  />

  <Section
    slotName="business-node-search"
    className="relative mb-72 mt-20"
  >
    <BusinessNodeSearch
      client:load
      provinces={provinces}
      popularNodes={popularNodesForSearch}
    />
  </Section>

